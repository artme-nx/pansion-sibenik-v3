{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "parchment": {
        "50": { "$value": "#FDF8EC", "$type": "color" },
        "100": { "$value": "#F7EDD3", "$type": "color" },
        "200": { "$value": "#EEDFB6", "$type": "color" },
        "300": { "$value": "#E2CB92", "$type": "color" },
        "400": { "$value": "#CDAE6C", "$type": "color" }
      },
      "burgundy": {
        "300": { "$value": "#A9505A", "$type": "color" },
        "500": { "$value": "#7A2732", "$type": "color" },
        "600": { "$value": "#611F28", "$type": "color" },
        "700": { "$value": "#4A171F", "$type": "color" },
        "900": { "$value": "#2C0D12", "$type": "color" }
      },
      "forest": {
        "400": { "$value": "#5C7256", "$type": "color" },
        "600": { "$value": "#3C5236", "$type": "color" },
        "700": { "$value": "#2A3C26", "$type": "color" }
      },
      "brass": {
        "300": { "$value": "#D8B968", "$type": "color" },
        "500": { "$value": "#B08A34", "$type": "color" },
        "700": { "$value": "#8A6B26", "$type": "color" }
      },
      "ink": {
        "700": { "$value": "#3A2A1E", "$type": "color" },
        "900": { "$value": "#241811", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-cinzel), 'Cinzel', Georgia, serif", "$type": "fontFamily" },
      "script": { "$value": "var(--font-tangerine), 'Tangerine', cursive", "$type": "fontFamily" },
      "body": { "$value": "var(--font-cormorant), 'Cormorant Garamond', Georgia, serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "200ms", "$type": "duration" },
        "base": { "$value": "400ms", "$type": "duration" },
        "reveal": { "$value": "1100ms", "$type": "duration" },
        "draw": { "$value": "1800ms", "$type": "duration" }
      },
      "ease": {
        "engrave": { "$value": "cubic-bezier(0.19, 1, 0.22, 1)", "$type": "cubicBezier" },
        "settle": { "$value": "cubic-bezier(0.33, 1, 0.68, 1)", "$type": "cubicBezier" }
      }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.parchment.100}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "popover": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "primary": { "$value": "{primitive.color.burgundy.600}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.forest.600}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "muted": { "$value": "{primitive.color.parchment.200}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.700}", "$type": "color" },
    "accent": { "$value": "{primitive.color.brass.500}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.burgundy.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.parchment.400}", "$type": "color" },
    "input": { "$value": "{primitive.color.parchment.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.burgundy.500}", "$type": "color" },
    "radius": { "$value": "0.25rem", "$type": "dimension" },
    "ink": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "burgundy-deep": { "$value": "{primitive.color.burgundy.700}", "$type": "color" },
    "burgundy-line": { "$value": "{primitive.color.burgundy.500}", "$type": "color" },
    "forest-deep": { "$value": "{primitive.color.forest.700}", "$type": "color" },
    "brass-line": { "$value": "{primitive.color.brass.500}", "$type": "color" },
    "parchment-deep": { "$value": "{primitive.color.parchment.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-script": { "$value": "{primitive.font.script}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.body}", "$type": "fontFamily" },
    "ease-engrave": { "$value": "{primitive.motion.ease.engrave}", "$type": "cubicBezier" },
    "ease-settle": { "$value": "{primitive.motion.ease.settle}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "duration-draw": { "$value": "{primitive.motion.duration.draw}", "$type": "duration" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.6rem, 7vw, 5.2rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.0", "$type": "number" }
    },
    "label-frame": {
      "outer-border": { "$value": "{primitive.color.burgundy.600}", "$type": "color" },
      "inner-border": { "$value": "{primitive.color.brass.500}", "$type": "color" },
      "panel-bg": { "$value": "{primitive.color.parchment.50}", "$type": "color" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.burgundy.600}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.burgundy.700}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.forest.600}", "$type": "color" }
    },
    "card": {
      "border": { "$value": "{primitive.color.parchment.400}", "$type": "color" },
      "shadow": { "$value": "0 12px 30px -18px rgba(42, 24, 15, 0.4)", "$type": "shadow" }
    }
  }
}
